<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .hero-gradient {
            background: linear-gradient(135deg, #10b981 0%, #334155 100%);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    
    <nav class="sticky top-0 z-50 glass shadow-sm py-4">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-emerald-600 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                NutriGuide
            </a>
            <div class="hidden md:flex gap-8 font-medium">
                <a href="#about" class="hover:text-emerald-500 transition">How it Works</a>
                <a href="#calculator" class="bg-emerald-600 text-white px-5 py-2 rounded-full hover:bg-emerald-700 transition">Get Started</a>
            </div>
        </div>
    </nav>

    <main class="flex-grow">
        <%- body %>
    </main>

    <footer class="bg-slate-900 text-slate-400 py-12 mt-20">
        <div class="container mx-auto px-6 text-center">
            <p class="text-white font-bold mb-4">NutriGuide Premium</p>
            <p class="mb-6">Empowering your health journey with clinical data and AI insights.</p>
            <div class="flex justify-center gap-6 text-sm">
                <a href="#terms-of-service" class="hover:text-white transition">Privacy Protocol</a>
                <a href="#how-it-works" class="hover:text-white transition">Clinical RAG</a>
                <a href="#terms-of-service" class="hover:text-white transition">Terms of Service</a>
            </div>
            <p class="mt-8 text-xs opacity-50">&copy; 2024 NutriGuide. Powered by Google Gemini.</p>
        </div>
    </footer>

</body>
</html>
