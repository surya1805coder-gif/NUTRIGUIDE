                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Weight (kg)</label>
                        <input type="number" step="0.1" name="weight" min="10" max="300" required class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none" placeholder="70.0">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Height (cm)</label>
                        <input type="number" name="height" min="50" max="250" required class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none" placeholder="175">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Activity Level</label>
                        <select name="activity" class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none appearance-none bg-white">
                            <option value="sedentary">Sedentary (Office job)</option>
                            <option value="light">Lightly Active (1-3 days/week)</option>
                            <option value="moderate">Moderately Active (3-5 days/week)</option>
                            <option value="active">Very Active (6-7 days/week)</option>
                            <option value="extra_active">Extremely Active (Physical job)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Average Daily Steps</label>
                        <input type="number" name="steps" min="0" max="50000" class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none" placeholder="5000">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Dietary Preference</label>
                        <select name="diet" class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none appearance-none bg-white">
                            <option value="vegetarian">Vegetarian</option>
                            <option value="non-vegetarian">Non-Vegetarian</option>
                            <option value="vegan">Vegan</option>
                            <option value="eggetarian">Eggetarian</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-slate-700">Health Goal</label>
                        <select name="goal" class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none appearance-none bg-white">
                            <option>Weight Loss</option>
                            <option>Muscle Gain</option>
                            <option>Energy Efficiency</option>
                            <option>Longevity/Vitality</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-slate-700">Plan Duration</label>
                    <select name="days" class="w-full px-4 py-3 rounded-2xl border-none ring-1 ring-slate-200 focus:ring-2 focus:ring-emerald-500 transition outline-none appearance-none bg-white">
                        <option value="1">1 Day (Quick Start)</option>
                        <option value="3">3 Days (Focused)</option>
                        <option value="5">5 Days (Standard)</option>
                        <option value="7">7 Days (Full Week)</option>
                    </select>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold hover:bg-emerald-600 transition duration-300 shadow-lg">
